[Unit]
Description=brunoosbrain memory doctor — RAG index + search-canary health (Track D)
After=network-online.target
Wants=network-online.target
OnFailure=brunoosbrain-alert@%n.service

[Service]
Type=oneshot
User=bruno
Group=bruno
WorkingDirectory=/home/bruno/claude-second-brain
EnvironmentFile=/home/bruno/claude-second-brain/.claude/.env
Environment=TZ=America/Sao_Paulo
Environment=PATH=/usr/local/bin:/usr/bin:/bin
ExecStart=/usr/local/bin/uv run python .claude/scripts/memory_doctor.py
TimeoutStartSec=360
LogsDirectory=brunoosbrain
StandardOutput=append:/var/log/brunoosbrain/memory-doctor.log
StandardError=append:/var/log/brunoosbrain/memory-doctor.log
