[Unit]
Description=brunoosbrain daily AI news digest
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
User=bruno
Group=bruno
WorkingDirectory=/home/bruno/claude-second-brain
EnvironmentFile=/home/bruno/claude-second-brain/.claude/.env
Environment=TZ=America/Sao_Paulo
Environment=PATH=/usr/local/bin:/usr/bin:/bin
ExecStart=/usr/local/bin/uv run python .claude/skills/news-digest/scripts/digest.py
TimeoutStartSec=600
LogsDirectory=brunoosbrain
StandardOutput=append:/var/log/brunoosbrain/news-digest.log
StandardError=append:/var/log/brunoosbrain/news-digest.log
