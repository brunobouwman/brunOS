[Unit]
Description=brunoosbrain vault git-sync (BrunOS/ ↔ GitHub)
After=network-online.target
Wants=network-online.target
# Fire the alert template if this sync fails, so a crash can't go silent.
OnFailure=brunoosbrain-alert@%n.service

[Service]
Type=oneshot
User=bruno
Group=bruno
# WorkingDirectory is the CODE repo (so `uv` finds pyproject.toml + .claude/.env);
# vault_sync.py resolves the vault itself via shared.vault_path().
WorkingDirectory=/home/bruno/claude-second-brain
Environment=TZ=America/Sao_Paulo
Environment=PATH=/usr/local/bin:/usr/bin:/bin
ExecStart=/usr/local/bin/uv run python .claude/scripts/vault_sync.py
TimeoutStartSec=120
LogsDirectory=brunoosbrain
StandardOutput=append:/var/log/brunoosbrain/vault-sync.log
StandardError=append:/var/log/brunoosbrain/vault-sync.log
