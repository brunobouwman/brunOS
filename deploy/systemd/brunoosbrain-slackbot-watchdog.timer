# Every 15 min. FAILOVER NOTE: stop this timer together with the slackbot
# (single-instance policy) or it alerts "unit-down" hourly — see the script
# docstring (BRUNOS_SLACKBOT_WATCHDOG_DISABLED is the .env alternative).
[Unit]
Description=brunoosbrain slackbot watchdog every 15 min

[Timer]
OnCalendar=*:00/15
RandomizedDelaySec=30
Persistent=false

[Install]
WantedBy=timers.target
