# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/
.pytest_cache/
.ruff_cache/
.mypy_cache/

# Virtualenv
.venv/
venv/

# Env / secrets
.env
.env.local
.env.*.local

# Runtime data (per-machine state, never commit)
.claude/data/
.claude/.env

# Local Codex app mirrors / context, not repo source of truth
.agents/
.codex/
AGENTS.md

# Vault (BrunOS/) is its own concern.
# Phase 9 will run `cd BrunOS && git init` so the vault syncs Mac<->VPS as its own repo.
# Until then, ignore from this (code) repo so it doesn't get half-tracked.
# Vault-internal ignores (e.g. Memory/drafts/active/*) live in BrunOS/.gitignore (Phase 9).
BrunOS/

# Packaged skill artifacts (regenerable via skill-creator/package_skill.py; source is tracked)
dist/

# Vault-unique skills are BRAIN-LOCAL, not shared code. They describe ONE brain's vault
# (folders, frontmatter, retrieval paths), so shipping them to another brain mis-teaches it.
# They live in .claude/skills/ so setting_sources=["project"] still loads them, but are
# gitignored so code-sync never propagates them. Each brain's copy is created during
# bootstrap (see Memory/projects/Brain/onboarding_installer.md "seed vault skills" step);
# BrunOS's instances are hand-created and kept locally per host.
.claude/skills/brunos-vault/
.claude/skills/memory-search/

# OS / editors
.DS_Store
Thumbs.db
*.swp
.idea/
.vscode/
