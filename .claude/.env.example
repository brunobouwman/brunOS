# === BrunOS environment ===
# Copy this file to `.claude/.env` and fill in values.
# `.claude/.env` is gitignored (see .gitignore); this `.claude/.env.example` is committed.
# Loaded by `shared.load_env()` (Phase 4) — every CLI / hook / SDK script picks it up.

# --- Vault path ---
# Absolute path to the BrunOS vault. On Mac this is the in-repo child dir;
# on VPS (Phase 9) it lives at /home/bruno/BrunOS. Always absolute, no trailing slash.
BRUNOS_VAULT_PATH=/Users/brunobouwman/Documents/brunOS-brain/BrunOS
GITHUB_USER=brunobouwman

# --- DB backend (Phase 3) ---
# sqlite on both Mac and VPS (Phase 9). DB file is per-host, rebuilt from synced vault.
DB_BACKEND=sqlite

# --- Anthropic auth (Phases 2, 6, 7) ---
# Default on Mac: the Claude Agent SDK auto-discovers Claude Code's OAuth credentials
# (Claude Max subscription) — leave ANTHROPIC_API_KEY UNSET. Phase 2's flush already runs this way.
# Default: leave UNSET on both Mac and VPS. The Agent SDK auto-discovers credentials in
# this order:
#   1. CLAUDE_CODE_OAUTH_TOKEN env var (portable 1-year token from `claude setup-token`)
#   2. ANTHROPIC_API_KEY env var (API credits, pay-per-call)
#   3. Local Claude Code OAuth state (~/.claude/, auto-refreshing)
#
# On Mac: Claude Code is logged in via your daily use, so #3 just works.
# On VPS: install Claude Code and run `claude login` once (device-code flow,
#   no port forwarding needed). SDK auto-discovers #3 there too. No env var needed.
#
# Set ANTHROPIC_API_KEY only if you want SDK calls billed against API credits instead
# of your Claude Max subscription.
# ANTHROPIC_API_KEY=

# --- Slack (Phase 4.1 + Phase 7) ---
# Phase 7 (chat bot) requires:
#   1. Bot Token scopes (Slack app → OAuth & Permissions):
#        - `chat:write`        — post replies in DMs and channel threads.
#        - `app_mentions:read` — receive `app_mention` events from channels.
#   2. App reinstalled in workspace after scope changes (banner prompts you).
#   3. Event Subscriptions → Subscribe to bot events:
#        - `message.im`   — DMs.
#        - `app_mention`  — channel @mentions of the bot.
#      Do NOT subscribe `message.channels` — pollutes the event stream.
#   4. Socket Mode enabled; the App-Level Token below needs `connections:write`.
#   5. Invite the bot into channels where you want to @mention it: `/invite @brunos`.
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=

# --- GitHub (Phase 4.2) ---
# Fine-grained PAT with per-repo Contents/Issues/PRs read+write, Metadata read
GITHUB_TOKEN=

# --- ClickUp (Phase 4.3) ---
# Token is user-scoped — one pk_... gives access to every workspace you belong to.
CLICKUP_API_TOKEN=
# Named workspaces in `name:team_id,name:team_id` format. Names are yours (used for CLI
# filtering: `query.py clickup overdue --workspace <name>`). Bruno's setup:
#   vertik     → contract work (labs/clinics sales-AI)
#   protostack → joint freelancing agency with Lisa
CLICKUP_WORKSPACES=vertik:90132121875,protostack:90151451527

# --- Google (Phase 4.4) ---
# Path (relative to repo root) to the OAuth client_secrets.json downloaded from
# Google Cloud Console → APIs & Services → Credentials → OAuth client ID (Desktop app).
# Required APIs enabled in the Cloud project: Gmail API + Google Calendar API.
GOOGLE_OAUTH_CLIENT_SECRETS_PATH=.claude/data/state/google_client_secrets.json
# Where the OAuth refresh-token gets persisted after the one-time `run_local_server` consent flow.
# Same file is scp'd to VPS in Phase 9 — refresh tokens bind to OAuth client_id, not the machine.
GOOGLE_OAUTH_TOKEN_PATH=.claude/data/state/google_token.json

# --- GitHub default repo (Phase 4.2) ---
# Used by `query.py github <subcommand>` when --repo is omitted. Format: owner/repo
GITHUB_DEFAULT_REPO=

# --- Vault sync observability (reliable git-sync, 2026-05) ---
# vault_sync.py replaces simonthum git-sync; these power its alerting + watchdog.
# Slack channel/DM ID for sync + ops FAILURE alerts (reuses SLACK_BOT_TOKEN above).
#   Find an ID via: uv run python .claude/scripts/query.py slack channels  (DMs look like D...).
BRUNOS_ALERT_CHANNEL=
# healthchecks.io ping URL for THIS host (one check per host: vps + mac).
#   vault_sync pings it on every success and <url>/fail on failure; if pings stop
#   entirely (timer/host dead) healthchecks.io alerts after the grace window.
BRUNOS_HEALTHCHECK_URL=
# Optional host label for commit identity + alert text (else inferred from hostname).
BRUNOS_SYNC_HOST_LABEL=
# healthchecks.io ping URL for the VPS code-sync (separate check from the vault sync).
#   code_sync.py pings on success and <url>/fail on failure; if pings stop, the
#   external dead-man's-switch alerts after the grace window. VPS-only.
BRUNOS_CODESYNC_HEALTHCHECK_URL=
# healthchecks.io ping URL for the daily reflection run (separate check). VPS-only.
#   memory_reflect.py emits ONE per-run verdict covering both stages: pings on
#   success, <url>/fail on a soft failure (JSON-parse / compaction-over-cap /
#   quarantine) or hard crash. Catches "reflection silently degraded or stopped".
BRUNOS_REFLECT_HEALTHCHECK_URL=
# healthchecks.io ping URL for the federation-doctor state-health check. VPS-only.
#   federation_doctor.py --alert pings on a healthy verdict, <url>/fail on stale-
#   uncleared / over-cap continuity doc / quarantined captures. INDEPENDENT of the
#   reflect check — catches a wedged reflection that never throws. Do NOT set on
#   the Mac (captures are never cleared there → permanent false "stale" alarm).
BRUNOS_FEDERATION_DOCTOR_HEALTHCHECK_URL=

# --- BrunOS → LinOS federation (Phase C.5) ---
# These apply only on specific hosts; leave unset on a normal BrunOS Mac/VPS.
#
# On the LinOS NODE (user `linos`, separate clone of this repo), set:
#   LINOS_VAULT_PATH   — LinOS's own vault (the consumer writes joint docs + acks here).
#   BRUNOS_VAULT_PATH  — point at the same LinOS vault so shared.vault_path() resolves
#                        correctly for LinOS's reflect/sync scripts (e.g. /home/linos/LinOS).
#   BRUNOS_INBOX_PATH  — the LinOS-readable inbox MIRROR the consumer reads (NOT bruno's
#                        real inbox; linos has no access to /home/bruno). Written only by
#                        the bruno-side cleared-push below.
# LINOS_VAULT_PATH=/home/linos/LinOS
# BRUNOS_INBOX_PATH=/home/linos/brunos-inbox/sessions
#
# On BRUNO's host, for the cleared-inbox push (deploy/bin/sync_cleared_inbox.py, runs as
# `bruno`): mirrors ONLY default_export==linos-protostack AND share_status==cleared captures
# into the LinOS-readable dest. Gate is scope+cleared, NEVER cleared-alone.
#   BRUNOS_INBOX_SRC   — source inbox (default /home/bruno/BrunOS/Memory/_inbox/sessions).
#   LINOS_INBOX_DEST   — the mirror dir linos reads (must match LinOS's BRUNOS_INBOX_PATH).
# BRUNOS_INBOX_SRC=/home/bruno/BrunOS/Memory/_inbox/sessions
# LINOS_INBOX_DEST=/home/linos/brunos-inbox/sessions

# --- Track D Phase 1: per-service healthchecks (2026-06-03) ---
# Same pattern as the four checks above: each service pings its check on success
# and <url>/fail on failure, with its status.json POSTed as the ping body (the
# fleet view reads rich state from the healthchecks API). One check per
# service per host; naming convention <brain>-<svc>-<host> (e.g.
# brunos-heartbeat-vps). Grace windows: 30-min ticks → 45 min; 15-min watchdog
# → 30 min; dailies → 26 h. Leave unset to disable a given check.
#
# Heartbeat tick outcome (VPS while it's primary; Mac during failover).
#   ok/fast-path/no-agent ping success; guardrail-blocked / agent-error /
#   gather-error / crash ping /fail + Slack alert.
BRUNOS_HEARTBEAT_HEALTHCHECK_URL=
# Slackbot watchdog (runs every 15 min where the bot runs; see failover note in
# .claude/scripts/slackbot_watchdog.py — stop the watchdog timer with the bot).
BRUNOS_SLACKBOT_HEALTHCHECK_URL=
# Memory doctor: RAG index freshness + sqlite integrity + search canary (daily).
BRUNOS_MEMORY_DOCTOR_HEALTHCHECK_URL=
# Comms-capture feeder (comms_capture.py, daily@22:00). Success ping carries the
# channels-selected / captures / channel-errors counts; /fail + alert only when
# EVERY configured channel failed (missing token / total model outage).
BRUNOS_COMMS_CAPTURE_HEALTHCHECK_URL=
# Mac→VPS raw-inbox rsync (deploy/bin/sync_inbox.py, Mac-only, every 2 min;
# grace ~10 min).
BRUNOS_INBOX_RSYNC_HEALTHCHECK_URL=
# bruno→LinOS cleared-inbox push (deploy/bin/sync_cleared_inbox.py, VPS-only).
BRUNOS_LINOS_INBOX_SYNC_HEALTHCHECK_URL=
# Mac producer-side retirement (deploy/bin/retire_local_inbox.py; reports in
# dry-run mode too — the dead-man proves the job runs during review).
BRUNOS_INBOX_RETIRE_HEALTHCHECK_URL=
# LinOS consumer loop (set on the LinOS node only).
# LINOS_CONSUMER_HEALTHCHECK_URL=
#
# Optional knobs:
#   BRUNOS_SEARCH_CANARY_QUERY         — memory-doctor canary query override.
#   BRUNOS_SLACKBOT_WATCHDOG_DISABLED  — set 1 to silence the watchdog (failover).
#   BRUNOS_DISABLE_REPORTING           — set 1 to disable ALL Track D reporting
#                                        (tests / ad-hoc runs); never set in prod.

 # When the flush model returns content that can't be parsed as the {work, personal}
# JSON split, which bucket does the unparsed blob fall into?
#   personal (default) — privacy-first: route to the daily log only, NEVER a
#                        company inbox. A parse failure can never leak.
#   work               — continuity-first: treat the blob as shareable work
#                        (eligible for the project inbox). Use only if losing
#                        project continuity on a malformed flush matters more
#                        than the privacy risk. The reflect-stage scrub still runs.
# Per-company privacy-vs-continuity business decision; defaults to personal.
BRUNOS_FLUSH_PARSE_FALLBACK=work
