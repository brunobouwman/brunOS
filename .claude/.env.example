# === BrunOS environment ===
# Copy this file to `.claude/.env` and fill in values.
# `.claude/.env` is gitignored (see .gitignore); this `.claude/.env.example` is committed.
# Loaded by `shared.load_env()` (Phase 4) — every CLI / hook / SDK script picks it up.

# --- Vault path ---
# Absolute path to the BrunOS vault. On Mac this is the in-repo child dir;
# on VPS (Phase 9) it lives at /home/bruno/BrunOS. Always absolute, no trailing slash.
BRUNOS_VAULT_PATH=/Users/brunobouwman/Documents/claude-second-brain/BrunOS

# --- DB backend (Phase 3) ---
# sqlite on both Mac and VPS (Phase 9). DB file is per-host, rebuilt from synced vault.
DB_BACKEND=sqlite

# --- Anthropic auth (Phases 2, 6, 7) ---
# Default on Mac: the Claude Agent SDK auto-discovers Claude Code's OAuth credentials
# (Claude Max subscription) — leave ANTHROPIC_API_KEY UNSET. Phase 2's flush already runs this way.
# Default: leave UNSET on both Mac and VPS. The Agent SDK auto-discovers credentials in
# this order:
#   1. CLAUDE_CODE_OAUTH_TOKEN env var (portable 1-year token from `claude setup-token`)
#   2. ANTHROPIC_API_KEY env var (API credits, pay-per-call)
#   3. Local Claude Code OAuth state (~/.claude/, auto-refreshing)
#
# On Mac: Claude Code is logged in via your daily use, so #3 just works.
# On VPS: install Claude Code and run `claude login` once (device-code flow,
#   no port forwarding needed). SDK auto-discovers #3 there too. No env var needed.
#
# Set ANTHROPIC_API_KEY only if you want SDK calls billed against API credits instead
# of your Claude Max subscription.
# ANTHROPIC_API_KEY=

# --- Slack (Phase 4.1 + Phase 7) ---
# Phase 7 (chat bot) requires:
#   1. Bot Token scopes (Slack app → OAuth & Permissions):
#        - `chat:write`        — post replies in DMs and channel threads.
#        - `app_mentions:read` — receive `app_mention` events from channels.
#   2. App reinstalled in workspace after scope changes (banner prompts you).
#   3. Event Subscriptions → Subscribe to bot events:
#        - `message.im`   — DMs.
#        - `app_mention`  — channel @mentions of the bot.
#      Do NOT subscribe `message.channels` — pollutes the event stream.
#   4. Socket Mode enabled; the App-Level Token below needs `connections:write`.
#   5. Invite the bot into channels where you want to @mention it: `/invite @brunos`.
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=

# --- GitHub (Phase 4.2) ---
# Fine-grained PAT with per-repo Contents/Issues/PRs read+write, Metadata read
GITHUB_TOKEN=

# --- ClickUp (Phase 4.3) ---
# Token is user-scoped — one pk_... gives access to every workspace you belong to.
CLICKUP_API_TOKEN=
# Named workspaces in `name:team_id,name:team_id` format. Names are yours (used for CLI
# filtering: `query.py clickup overdue --workspace <name>`). Bruno's setup:
#   vertik     → contract work (labs/clinics sales-AI)
#   protostack → joint freelancing agency with Lisa
CLICKUP_WORKSPACES=vertik:90132121875,protostack:90151451527

# --- Google (Phase 4.4) ---
# Path (relative to repo root) to the OAuth client_secrets.json downloaded from
# Google Cloud Console → APIs & Services → Credentials → OAuth client ID (Desktop app).
# Required APIs enabled in the Cloud project: Gmail API + Google Calendar API.
GOOGLE_OAUTH_CLIENT_SECRETS_PATH=.claude/data/state/google_client_secrets.json
# Where the OAuth refresh-token gets persisted after the one-time `run_local_server` consent flow.
# Same file is scp'd to VPS in Phase 9 — refresh tokens bind to OAuth client_id, not the machine.
GOOGLE_OAUTH_TOKEN_PATH=.claude/data/state/google_token.json

# --- GitHub default repo (Phase 4.2) ---
# Used by `query.py github <subcommand>` when --repo is omitted. Format: owner/repo
GITHUB_DEFAULT_REPO=
